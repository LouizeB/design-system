{
  "color": {
    "action": {
      "primary":            { "$value": "{color.wireframe.400}", "$type": "color" },
      "primary-hover":      { "$value": "{color.wireframe.500}", "$type": "color" },
      "primary-subtle":     { "$value": "{color.wireframe.100}", "$type": "color" },
      "primary-foreground": { "$value": "{color.neutral.0}",     "$type": "color" },
      "secondary-foreground": { "$value": "{color.wireframe.500}", "$type": "color" }
    },
    "background": {
      "default": { "$value": "{color.neutral.0}",       "$type": "color" },
      "surface":  { "$value": "{color.wireframe.100}",   "$type": "color" },
      "hover":    { "$value": "{color.wireframe.200}",   "$type": "color" }
    },
    "text": {
      "primary":   { "$value": "{color.wireframe.500}", "$type": "color" },
      "secondary": { "$value": "{color.wireframe.400}", "$type": "color" },
      "inverse":   { "$value": "{color.neutral.0}",     "$type": "color" }
    },
    "border": {
      "default": { "$value": "{color.wireframe.200}", "$type": "color" }
    },
    "feedback": {
      "success": { "$value": "{color.wireframe.300}", "$type": "color" },
      "warning": { "$value": "{color.wireframe.300}", "$type": "color" },
      "error":   { "$value": "{color.wireframe.300}", "$type": "color" },
      "info":    { "$value": "{color.wireframe.300}", "$type": "color" }
    }
  }
}
