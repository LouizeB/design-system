{
  "color": {
    "action": {
      "primary":            { "$value": "{color.purple.500}",  "$type": "color" },
      "primary-hover":      { "$value": "{color.purple.600}",  "$type": "color" },
      "primary-subtle":     { "$value": "{color.purple.50}",   "$type": "color" },
      "primary-foreground": { "$value": "{color.neutral.0}",   "$type": "color" },
      "secondary-foreground": { "$value": "{color.purple.500}", "$type": "color" }
    },
    "background": {
      "default": { "$value": "{color.neutral.900}", "$type": "color" },
      "surface":  { "$value": "{color.neutral.800}", "$type": "color" },
      "hover":    { "$value": "{color.neutral.700}", "$type": "color" }
    },
    "text": {
      "primary":   { "$value": "{color.neutral.0}",   "$type": "color" },
      "secondary": { "$value": "{color.neutral.400}", "$type": "color" },
      "inverse":   { "$value": "{color.neutral.900}", "$type": "color" }
    },
    "border": {
      "default": { "$value": "{color.neutral.700}", "$type": "color" }
    },
    "feedback": {
      "success": { "$value": "{color.green.500}",  "$type": "color" },
      "warning": { "$value": "{color.amber.500}",  "$type": "color" },
      "error":   { "$value": "{color.red.500}",    "$type": "color" },
      "info":    { "$value": "{color.blue.500}",   "$type": "color" }
    }
  }
}
