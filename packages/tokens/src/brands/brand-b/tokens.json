{
  "color": {
    "action": {
      "primary":            { "$value": "{color.green.500}",   "$type": "color" },
      "primary-hover":      { "$value": "{color.green.600}",   "$type": "color" },
      "primary-subtle":     { "$value": "{color.green.50}",    "$type": "color" },
      "primary-foreground": { "$value": "{color.neutral.0}",   "$type": "color" },
      "secondary-foreground": { "$value": "{color.green.500}", "$type": "color" }
    },
    "background": {
      "default": { "$value": "{color.neutral.900}", "$type": "color" },
      "surface":  { "$value": "{color.neutral.800}", "$type": "color" },
      "hover":    { "$value": "{color.neutral.700}", "$type": "color" }
    },
    "text": {
      "primary":   { "$value": "{color.neutral.0}",   "$type": "color" },
      "secondary": { "$value": "{color.neutral.400}", "$type": "color" },
      "inverse":   { "$value": "{color.neutral.900}", "$type": "color" }
    },
    "border": {
      "default": { "$value": "{color.neutral.700}", "$type": "color" }
    },
    "feedback": {
      "success": { "$value": "{color.palette.feedback.success}", "$type": "color" },
      "warning": { "$value": "{color.palette.feedback.warning}", "$type": "color" },
      "error":   { "$value": "{color.palette.feedback.error}",   "$type": "color" },
      "info":    { "$value": "{color.palette.feedback.info}",    "$type": "color" }
    }
  }
}
